<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ratings</title>
  <link rel="stylesheet" href="/ratings.css" />
  <script src="/ratingScript.js" defer></script>
</head>
<body>
  <nav class="navbar">
    <div class="navbar-logo">
      <img src="https://images.squarespace-cdn.com/content/v1/5b328976aa49a1b7b46b89c3/1530039440176-O24B7OCR4WPIAI62JZTW/CompSci.High_Circle_Logo.png?format=750w" alt="School Logo" />
    </div>
    <div class="nav-links">
      <a href="/">Teachers</a>
      <a href="/ratings">Comments & Ratings</a>
    </div>
  </nav>

  <div class="container">
    <h1>CSH Teacher Comments & Ratings</h1>

    <div class="form-section">
      <h2>Leave a Comment</h2>

      

    <div class="teachers-grid">
      <% for (let i = 0; i < ratings.length; i++) { %>
        <div class="teacher-card">
          <div class="teacher-card-content">
            <h2><%= ratings[i].teacher %></h2>
            <div class="stars">
              <% for (let x = 0; x < ratings[i].rating; x++) { %>
                ⭐
              <% } %>
              <% for (let x = ratings[i].rating; x < 5; x++) { %>
                ☆
              <% } %>
            </div>
            <p><strong>Comment:</strong> <%= ratings[i].comment %></p>
            <p><em>By: <%= ratings[i].username %></em></p>
            <!-- Add a button that calls a deleteRating function with its id passed as input -->

<!-- Edit Form -->
           <form class="edit-form" id="editForm<%= i %>" style="display:none;">
             <label>Username: </label>
             <input type="text" name="username" value="<%= ratings[i].username %>" required />
            
             <label>Teacher: </label>
             <input type="text" name="teacher" value="<%= ratings[i].teacher %>" />
            
             <label>Comment: </label>
             <input type="text" name="comment" value="<%= ratings[i].image %>" />


             <label>Ratings: </label>
             <input type="text" name="ratings" value="<%= ratings[i].image %>" />
            
             <button type="submit">Save</button>
             <button type="button" onclick="cancelEdit('<%= i %>')">Cancel</button>
           </form>
          
           <!-- Action Buttons -->
           <button onclick="toggleEditForm('<%= i %>')">Edit Ratings</button>
           <button onclick="deleteRatings('<%= ratings[i]._id %>')">Delete Ratings</button>
         </div>


          </div>
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>
